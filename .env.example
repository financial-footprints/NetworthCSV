## Core
### Path to the account configuration file
ACCOUNT_CONFIG_PATH=./accounts.json
### Path to the directory where statements will be downloaded
DOWNLOAD_PATH=/path/to/statements

## Statement Source
### Source type: thunderbird | email
SOURCE_TYPE=thunderbird
### When SOURCE_TYPE=email
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_USERNAME=your.email@gmail.com
# IMAP_PASSWORD=your-app-password
# IMAP_FOLDER=[Gmail]/All Mail
### When SOURCE_TYPE=thunderbird
# THUNDERBIRD_PROFILE=/path/to/thunderbird/profile

## Alerts
ALERTS_TYPE=console
### Alert notifications:Outbound SMTP
### When ALERTS_TYPE=email
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=alerts@example.com
# SMTP_PASSWORD=secret
# SMTP_FROM_ADDRESS=alerts@example.com
# SMTP_TO=you@example.com

## Advanced
### Optional: chain to another env file
### Up to 10 hops; merges additively.
# ENV_PATH=/path/to/networthcsv.secrets.env
## Log level
LOG_LEVEL=info
